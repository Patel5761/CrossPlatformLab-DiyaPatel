name: Multi-OS Testing - Diya

on:
  push:
    branches:
      - master

jobs:
  test-ubuntu:
    name: test-ubuntu
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Start Ubuntu Testing
        run: echo "Testing on Ubuntu..."

      - name: Print Ubuntu System Info
        run: uname -a

      - name: Create and Read Ubuntu File
        run: |
          echo "Ubuntu test by Diya" > test-ubuntu.txt
          cat test-ubuntu.txt

      - name: Complete Ubuntu Testing
        run: echo "Ubuntu tests completed"

  test-windows:
    name: test-windows
    runs-on: windows-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Start Windows Testing
        run: echo "Testing on Windows..."

      - name: Print Windows System Info
        run: systeminfo

      - name: Create and Read Windows File
        run: |
          echo "Windows test by Diya" > test-windows.txt
          type test-windows.txt

      - name: Complete Windows Testing
        run: echo "Windows tests completed"
